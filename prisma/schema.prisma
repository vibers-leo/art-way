// Prisma 스키마 — Supabase에서 자체 PostgreSQL로 마이그레이션

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 전시 테이블
model Exhibition {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz
  title          String
  artist         String?
  description    String?
  start_date     DateTime? @db.Date
  end_date       DateTime? @db.Date
  is_active      Boolean?  @default(true)
  poster_url     String?
  is_main_slider Boolean?  @default(false)
  youtube_url    String?

  @@map("exhibitions")
}

// 보도자료 테이블
model MediaRelease {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz
  title          String
  press_name     String?
  link_url       String?
  content        String?
  image_url      String?
  published_date DateTime? @db.Date

  @@map("media_releases")
}

// 메인 배너 테이블
model MainBanner {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz
  youtube_url String
  is_active   Boolean? @default(true)

  @@map("main_banner")
}

// 문의 테이블
model Inquiry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type       String   // 'general' | 'exhibition'
  name       String
  phone      String
  email      String?
  content    String
  status     String?  @default("new") // 'new' | 'read' | 'done'
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("inquiries")
}

// 일별 방문자 통계 테이블
model DailyStat {
  date       DateTime @id @db.Date
  count      Int      @default(0)
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("daily_stats")
}

// 사이트 설정 테이블
model SiteSetting {
  id             Int      @id @default(1)
  og_description String?  @default("부산 동구 문화 예술 공간")
  og_image_url   String?
  updated_at     DateTime @default(now()) @db.Timestamptz

  @@map("site_settings")
}
